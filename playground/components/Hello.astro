---
const title = "Hello from Astro";
const items = ["a", "b", "c"];
---

<section class="hello-astro">
  <h2>{title}</h2>
  <p>This block was rendered by Astro's Container API at build/dev time, then handed to Slidev as a Vue component.</p>
  <ul>
    {items.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .hello-astro {
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #1e293b, #0f172a);
    color: #f8fafc;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }
  .hello-astro h2 {
    margin: 0 0 0.5rem;
    font-size: 1.4rem;
    color: #f97316;
  }
  .hello-astro ul {
    margin: 0.5rem 0 0 1rem;
    padding: 0;
  }
</style>
