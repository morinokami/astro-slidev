---
const highlights = [
    "Write expressive Astro markup",
    "Keep slide-specific UI self-contained",
    "Ship polished static blocks with scoped styles",
];
---

<section class="hello-astro">
    <p class="eyebrow">Astro component</p>
    <h2>Bring Astro-authored UI into your slides</h2>
    <p>
        Build rich static sections with familiar Astro syntax, then drop them
        into a deck as reusable slide components.
    </p>
    <ul>
        {highlights.map((item) => <li>{item}</li>)}
    </ul>
</section>

<style>
    .hello-astro {
        padding: 1.4rem 1.6rem;
        border-radius: 0.5rem;
        background: #102a43;
        color: #f8fafc;
        border-left: 0.45rem solid #ff5d01;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.18);
    }
    .hello-astro .eyebrow {
        margin: 0 0 0.35rem;
        color: #8ecae6;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    .hello-astro h2 {
        margin: 0 0 0.65rem;
        font-size: 1.55rem;
        line-height: 1.18;
        color: #ffffff;
    }
    .hello-astro p {
        margin: 0;
        line-height: 1.55;
    }
    .hello-astro code {
        padding: 0.05rem 0.3rem;
        border-radius: 0.25rem;
        background: rgba(255, 255, 255, 0.12);
    }
    .hello-astro ul {
        display: grid;
        gap: 0.35rem;
        margin: 0.85rem 0 0;
        padding: 0;
        list-style: none;
    }
    .hello-astro li::before {
        content: "✔︎";
        display: inline-block;
        margin-right: 0.5rem;
        color: #ff5d01;
        font-size: 0.72rem;
        font-weight: 800;
    }
</style>
