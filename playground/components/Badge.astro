---
const { label } = Astro.props;
---

<span class="badge">{label}</span>

<style>
  .badge {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    background: #f97316;
    color: #0f172a;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
</style>
