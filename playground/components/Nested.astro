---
import Card from "./Card.astro";
---

<section class="nested-demo">
  <Card title="Nested .astro" tags={["astro", "slidev"]}>
    <p>This <code>Card</code> imports a <code>Badge</code> from another <code>.astro</code> file. Both are compiled recursively and their scoped styles are routed through Vite's CSS pipeline.</p>
  </Card>
</section>

<style>
  .nested-demo {
    display: grid;
    gap: 0.75rem;
  }
  .nested-demo code {
    background: #1e293b;
    padding: 0 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
</style>
