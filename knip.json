{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "entry": ["vite.config.ts"],
      "ignoreDependencies": ["@arethetypeswrong/cli", "publint", "@ls-lint/ls-lint", "sherif"]
    },
    "packages/astro-slidev": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@typescript/native-preview"]
    },
    "playground": {
      "entry": ["vite.config.ts", "setup/*.ts", "components/**/*.{astro,vue}", "snippets/**/*.ts"],
      "project": ["**/*.{ts,vue,astro}"],
      "ignoreDependencies": ["@slidev/theme-default", "@slidev/theme-seriph"]
    }
  }
}
